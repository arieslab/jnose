package io.github.arieslab.pages;

import io.github.arieslab.WicketTestBase;
import org.junit.jupiter.api.Test;

class PageRenderingTest extends WicketTestBase {

    @Test
    void testHomePageRenders() {
        tester.startPage(HomePage.class);
        tester.assertRenderedPage(HomePage.class);
        tester.assertNoErrorMessage();
    }

    @Test
    void testConfigPageRenders() {
        tester.startPage(ConfigPage.class);
        tester.assertRenderedPage(ConfigPage.class);
        tester.assertNoErrorMessage();
    }

    @Test
    void testProjetosPageRenders() {
        tester.startPage(ProjetosPage.class);
        tester.assertRenderedPage(ProjetosPage.class);
        tester.assertNoErrorMessage();
    }

    @Test
    void testByClassTestPageRenders() {
        tester.startPage(ByClassTestPage.class);
        tester.assertRenderedPage(ByClassTestPage.class);
        tester.assertNoErrorMessage();
    }

    @Test
    void testByTestSmellsPageRenders() {
        tester.startPage(ByTestSmellsPage.class);
        tester.assertRenderedPage(ByTestSmellsPage.class);
        tester.assertNoErrorMessage();
    }

    @Test
    void testResearchPageRenders() {
        tester.startPage(ResearchPage.class);
        tester.assertRenderedPage(ResearchPage.class);
        tester.assertNoErrorMessage();
    }

    @Test
    void testAnalyzePageRenders() {
        tester.startPage(AnalyzePage.class);
        tester.assertRenderedPage(AnalyzePage.class);
        tester.assertNoErrorMessage();
    }
}
